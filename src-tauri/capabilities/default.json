{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Markdown-Viewer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:menu:default",
    "core:window:default",
    "core:event:default",
    "dialog:default",
    "shell:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": []
    }
  ]
}
